# name: test/sql/delta_export.test
# group: [sql]

require delta_export

require delta

require json

require parquet

require ducklake

# ── Create a real DuckLake catalog ──

statement ok
ATTACH 'ducklake:__TEST_DIR__/test_metadata.ducklake' AS test_lake (DATA_PATH '__TEST_DIR__/test_data');

statement ok
USE test_lake;

statement ok
CREATE TABLE test_table (id BIGINT, name VARCHAR);

statement ok
INSERT INTO test_table VALUES (1, 'Alice'), (2, 'Bob'), (3, 'Charlie');

# ── First export: table should need export ──

query TT
SELECT table_name, status FROM delta_export();
----
main.test_table	needs_export

# ── Complex transactions: insert, update, delete then export ──

statement ok
CREATE TABLE sales (id BIGINT, amount DOUBLE, region VARCHAR);

statement ok
INSERT INTO sales VALUES (1, 10.0, 'US'), (2, 20.0, 'EU'), (3, 30.0, 'US'), (4, 40.0, 'APAC'), (5, 50.0, 'EU'), (6, 60.0, 'US');

statement ok
UPDATE sales SET amount = amount * 1.1 WHERE region = 'EU';

statement ok
DELETE FROM sales WHERE id = 4;

statement ok
INSERT INTO sales VALUES (7, 70.0, 'APAC'), (8, 80.0, 'US');

statement ok
UPDATE sales SET region = 'NA' WHERE region = 'US';

# Flush inlined data and rewrite files with deletes before export

statement ok
CALL test_lake.set_option('rewrite_delete_threshold', 0);

statement ok
CALL ducklake_flush_inlined_data('test_lake');

statement ok
CALL ducklake_rewrite_data_files('test_lake');

query TT
SELECT table_name, status FROM delta_export() WHERE table_name = 'main.sales';
----
main.sales	needs_export

# ── Verify DuckLake row count matches after export ──

query I
SELECT count(*) FROM sales;
----
7

# ── Data inlining: small inserts go to metadata ──

statement ok
CREATE TABLE products (id BIGINT, name VARCHAR, price DOUBLE);

statement ok
CALL test_lake.set_option('data_inlining_row_limit', 10);

statement ok
INSERT INTO products VALUES (1, 'Widget', 9.99), (2, 'Gadget', 19.99), (3, 'Gizmo', 29.99);

statement ok
DELETE FROM products WHERE id = 2;

statement ok
INSERT INTO products VALUES (4, 'Doohickey', 39.99);

statement ok
CALL test_lake.set_option('rewrite_delete_threshold', 0);

statement ok
CALL ducklake_flush_inlined_data('test_lake');

statement ok
CALL ducklake_rewrite_data_files('test_lake');

query TT
SELECT table_name, status FROM delta_export() WHERE table_name = 'main.products';
----
main.products	needs_export

query I
SELECT count(*) FROM products;
----
3

# ── Data type mappings ──

statement ok
CREATE TABLE typed_table (col_tinyint TINYINT, col_smallint SMALLINT, col_integer INTEGER, col_bigint BIGINT, col_float FLOAT, col_double DOUBLE, col_boolean BOOLEAN, col_varchar VARCHAR, col_date DATE, col_timestamp TIMESTAMP);

statement ok
INSERT INTO typed_table VALUES (1, 100, 1000, 100000, 1.5, 2.5, true, 'hello', '2024-01-01', '2024-01-01 12:00:00');

query TT
SELECT table_name, status FROM delta_export() WHERE table_name = 'main.typed_table';
----
main.typed_table	needs_export

query I
SELECT count(*) FROM typed_table;
----
1
